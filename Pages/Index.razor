@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Cotton Broker Automation System</PageTitle>

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-4">Cotton Broker Automation System</h1>
        <p class="lead">Hệ thống Tự động Xử lý Offer Bông</p>
        <hr class="my-4" />
        
        <div class="row mt-5">
            <div class="col-md-6 offset-md-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Chức năng chính</h5>
                        <ul class="list-group list-group-flush text-start">
                            <li class="list-group-item">📄 Upload Offer PDF từ Shipper</li>
                            <li class="list-group-item">📊 Upload nhiều HVI Report PDF</li>
                            <li class="list-group-item">⚙️ Tự động parse và liên kết dữ liệu</li>
                            <li class="list-group-item">💰 Tính giá tự động theo công thức</li>
                            <li class="list-group-item">📑 Xuất Excel format chuẩn</li>
                        </ul>
                        <a href="/offer-processor" class="btn btn-primary btn-lg mt-3">
                            Bắt đầu xử lý Offer →
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
