@page "/lots"
@using CBAS.Web.Data
@using CBAS.Web.Models
@using CBAS.Web.DTOs
@using CBAS.Web.Services
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@inject IExcelExportService ExcelExport
@inject IJSRuntime JS

<PageTitle>Quản lý Lot</PageTitle>

<div class="container-fluid py-3" style="font-size:0.82rem;">

    @* ── Header: title + ICE/Commission + Export button ── *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Quản lý Lot hàng <span class="badge bg-info">@(lots?.Count ?? 0) lots</span></h5>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-1">
                <label class="fw-bold small text-nowrap">ICE:</label>
                <input type="number" step="0.01" class="form-control form-control-sm" style="width:90px" @bind="iceValue" @bind:event="oninput" />
            </div>
            <div class="d-flex align-items-center gap-1">
                <label class="fw-bold small text-nowrap">Comm%:</label>
                <input type="number" step="0.01" class="form-control form-control-sm" style="width:80px" @bind="commissionPercent" @bind:event="oninput" />
            </div>
            <button class="btn btn-success btn-sm text-nowrap" @onclick="ExportSelectedLots" disabled="@(!selectedLotIds.Any())">
                Tạo Output (@selectedLotIds.Count)
            </button>
            <button class="btn btn-danger btn-sm text-nowrap" @onclick="DeleteSelectedLots" disabled="@(!selectedLotIds.Any())">
                Xóa (@selectedLotIds.Count)
            </button>
        </div>
    </div>

    @* ── Filters ── *@
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col"><label class="form-label small mb-0">Shipper</label>
                    <select class="form-select form-select-sm" @bind="filterShipper"><option value="0">Tất cả</option>
                        @foreach (var s in shipperList) { <option value="@s.ShipperId">@s.Name</option> }
                    </select></div>
                <div class="col"><label class="form-label small mb-0">Origin</label>
                    <select class="form-select form-select-sm" @bind="filterOrigin"><option value="">Tất cả</option>
                        @foreach (var o in originList) { <option value="@o">@o</option> }
                    </select></div>
                <div class="col"><label class="form-label small mb-0">Status</label>
                    <select class="form-select form-select-sm" @bind="filterStatus">
                        <option value="-1">Tất cả</option><option value="0">Available</option><option value="1">Reserved</option><option value="2">Sold</option>
                    </select></div>
                <div class="col"><label class="form-label small mb-0">Shipment</label>
                    <input type="month" class="form-control form-control-sm" @bind="filterShipmentMonth" /></div>
                <div class="col"><label class="form-label small mb-0">Lot Code</label>
                    <input class="form-control form-control-sm" @bind="filterLotCode" placeholder="ME066..." /></div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" @onclick="ApplyFilter">Lọc</button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="ClearFilter">Xóa</button>
                </div>
            </div>
        </div>
    </div>

    @* ── Summary cards ── *@
    @if (lots != null)
    {
        <div class="row mb-2 g-2">
            <div class="col"><div class="card border-success"><div class="card-body py-1 text-center">
                <span class="text-muted small">Available</span><br/><strong class="text-success">@lots.Count(l => l.Status == LotStatus.Available)</strong>
            </div></div></div>
            <div class="col"><div class="card border-warning"><div class="card-body py-1 text-center">
                <span class="text-muted small">Reserved</span><br/><strong class="text-warning">@lots.Count(l => l.Status == LotStatus.Reserved)</strong>
            </div></div></div>
            <div class="col"><div class="card border-secondary"><div class="card-body py-1 text-center">
                <span class="text-muted small">Sold</span><br/><strong class="text-secondary">@lots.Count(l => l.Status == LotStatus.Sold)</strong>
            </div></div></div>
            <div class="col"><div class="card border-primary"><div class="card-body py-1 text-center">
                <span class="text-muted small">Total QTY Avail</span><br/><strong class="text-primary">@lots.Where(l => l.Status == LotStatus.Available).Sum(l => l.QuantityAvailable).ToString("F0") mt</strong>
            </div></div></div>
        </div>
    }

    @* ── Side-by-side Comparison Panel ── *@
    <div class="card mb-2">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-1">
            <h6 class="mb-0"><i class="bi bi-layout-split me-1"></i>Đối chiếu Offer gốc</h6>
            <div class="d-flex align-items-center gap-2">
                <select class="form-select form-select-sm bg-dark text-white border-secondary" style="width:280px;font-size:0.75rem;" @bind="selectedOfferId" @bind:after="LoadOfferComparison">
                    <option value="0">-- Chọn Offer để đối chiếu --</option>
                    @foreach (var o in offerList)
                    {
                        <option value="@o.OfferId">@o.OfferDate.ToString("dd/MM/yy") — @o.SupplierName (@o.FileName)</option>
                    }
                </select>
                <button class="btn btn-sm btn-outline-light" @onclick="() => showOfferComparison = !showOfferComparison" disabled="@(selectedOfferId == 0)">
                    @(showOfferComparison ? "Thu gọn ▲" : "Mở xem ▼")
                </button>
            </div>
        </div>
        @if (showOfferComparison && selectedOfferId > 0 && comparisonOfferLots != null)
        {
            <div class="card-body p-2" style="font-size:0.75rem;">
                <div class="row g-2">
                    @* LEFT: Raw PDF Text *@
                    <div class="col-md-4">
                        <div class="border rounded p-2 bg-light" style="height:400px; overflow-y:auto;">
                            <h6 class="fw-bold text-muted mb-1" style="font-size:0.75rem;">📄 PDF Text gốc</h6>
                            <pre id="lotPdfTextPanel" style="white-space:pre-wrap; font-size:0.7rem; font-family:monospace; line-height:1.4; margin:0;">@(comparisonPdfText ?? "Offer này chưa có PDF text (upload trước v2.2)")</pre>
                        </div>
                    </div>
                    @* RIGHT: OfferLots from that Offer *@
                    <div class="col-md-8">
                        <div class="border rounded" style="height:400px; overflow:auto;">
                            <table class="table table-bordered table-hover table-sm mb-0" style="font-size:0.7rem;">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th>#</th>
                                        <th>LotCode</th>
                                        <th>Origin</th>
                                        <th>Crop</th>
                                        <th>QTY</th>
                                        <th>Type</th>
                                        <th>Color</th>
                                        <th>Leaf</th>
                                        <th>Staple</th>
                                        <th>Mic</th>
                                        <th>Str</th>
                                        <th>Basis</th>
                                        <th>Fixed</th>
                                        <th>Settle</th>
                                        <th>Ship</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int cmpRow = 0; }
                                    @foreach (var ol in comparisonOfferLots)
                                    {
                                        cmpRow++;
                                        var bDisplay = ol.BasisCents != 0 ? (ol.BasisCents * 100m).ToString("N0") : "";
                                        var fDisplay = ol.OutrightPrice != 0 ? ol.OutrightPrice.ToString("N2") : "";
                                        <tr class="@(highlightedOfferLotId == ol.LotId ? "table-warning" : "")" style="cursor:pointer;"
                                            @onclick="() => HighlightOfferLot(ol)" title="Click để tìm trong PDF text">
                                            <td class="text-muted">@cmpRow</td>
                                            <td class="fw-bold">@ol.LotCode</td>
                                            <td>@ol.Origin</td>
                                            <td>@ol.CropYear</td>
                                            <td class="text-end">@(ol.Quantity > 0 ? ol.Quantity.ToString("N0") : "—")</td>
                                            <td>@ol.Type</td>
                                            <td>@ol.ColorSpec</td>
                                            <td>@ol.LeafSpec</td>
                                            <td>@ol.LengthSpec</td>
                                            <td>@ol.MicronaireSpec</td>
                                            <td>@ol.StrengthSpec</td>
                                            <td class="text-end">@bDisplay</td>
                                            <td class="text-end">@fDisplay</td>
                                            <td>@ol.SettlementMonth</td>
                                            <td>@ol.ShipmentDateText</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="mt-1 text-muted" style="font-size:0.7rem;">
                    <i class="bi bi-info-circle me-1"></i>Click dòng lot để highlight text tương ứng trong PDF gốc.
                </div>
            </div>
        }
    </div>

    @* ── Lot Table ── *@
    <style>
        .lot-grid { font-size: 0.75rem; border-collapse: collapse; }
        .lot-grid th, .lot-grid td { border: 1px solid #dee2e6; padding: 3px 6px; white-space: nowrap; vertical-align: middle; }
        .lot-grid thead th { position: sticky; top: 0; z-index: 2; background: #212529; color: #fff; border-color: #495057; font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.02em; }
        .lot-grid tbody tr:hover { background: #e8f4fd !important; }
        .lot-grid tbody tr:nth-child(even) { background: #f8f9fa; }
        .lot-grid tbody tr.row-selected { background: #cfe2ff !important; }
        /* Column group backgrounds */
        .col-info { background: rgba(13,110,253,0.04); }
        .col-qty { background: rgba(25,135,84,0.05); }
        .col-hvi { background: rgba(255,193,7,0.06); }
        .col-price { background: rgba(220,53,69,0.04); }
        .col-price.fw-bold { color: #b02a37; }
    </style>
    <div class="card">
        <div class="table-responsive" style="max-height:72vh; overflow-y:auto;">
            <table class="table table-sm mb-0 align-middle lot-grid">
                <thead>
                    <tr>
                        <th style="width:30px"><input type="checkbox" @onchange="ToggleSelectAll" /></th>
                        <th style="width:35px">#</th>
                        <th>Lot Code</th>
                        <th>Shipper</th>
                        <th>Origin</th>
                        <th>Crop</th>
                        <th>Type / Spec</th>
                        <th>Shipment</th>
                        <th class="text-end">Orig</th>
                        <th class="text-end">Avail</th>
                        <th class="text-center" style="border-left:2px solid #ffc107">Mic</th>
                        <th class="text-center">Len</th>
                        <th class="text-center" style="border-right:2px solid #ffc107">GPT</th>
                        <th class="text-end" style="border-left:2px solid #dc3545">Basis</th>
                        <th class="text-end">c/kg</th>
                        <th class="text-end">+Comm</th>
                        <th class="text-end" style="border-right:2px solid #dc3545">Net</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">HVI</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lots == null)
                    {
                        <tr><td colspan="20" class="text-center py-3">Đang tải...</td></tr>
                    }
                    else if (!lots.Any())
                    {
                        <tr><td colspan="20" class="text-center py-3 text-muted">Không có lot nào</td></tr>
                    }
                    else
                    {
                        int stt = 1;
                        @foreach (var lot in lots)
                        {
                            var hvi = lot.HVIReport;
                            var priceCkg = CalcPriceCkg(lot);
                            var priceComm = priceCkg - commissionPercent;
                            var priceNet = priceComm;
                            <tr class="@(selectedLotIds.Contains(lot.Id) ? "row-selected" : "")">
                                <td><input type="checkbox" checked="@selectedLotIds.Contains(lot.Id)" @onchange="e => ToggleLot(lot.Id, (bool)(e.Value ?? false))" /></td>
                                <td class="text-muted">@(stt++)</td>
                                <td class="col-info"><strong>@lot.LotCode</strong></td>
                                <td class="col-info text-truncate" style="max-width:120px" title="@lot.Shipper?.Name">@lot.Shipper?.Name</td>
                                <td class="col-info">@lot.Origin</td>
                                <td class="col-info">@lot.CropYear</td>
                                <td class="col-info text-truncate" style="max-width:200px" title="@lot.Type @lot.SpecialSpec">@lot.Type @lot.SpecialSpec</td>
                                <td class="col-info">@lot.ShipmentDateText</td>
                                <td class="col-qty text-end">@lot.QuantityOriginal.ToString("F0")</td>
                                <td class="col-qty text-end fw-bold">@lot.QuantityAvailable.ToString("F0")</td>
                                <td class="col-hvi text-center" style="border-left:2px solid #ffc107">@hvi?.Micronaire?.ToString("F1")</td>
                                <td class="col-hvi text-center">@hvi?.Length?.ToString("F2")</td>
                                <td class="col-hvi text-center" style="border-right:2px solid #ffc107">@hvi?.StrengthGPT?.ToString("F1")</td>
                                <td class="col-price text-end" style="border-left:2px solid #dc3545">@((lot.BasisCents * 100m).ToString("F0"))</td>
                                <td class="col-price text-end fw-bold">@priceCkg.ToString("F2")</td>
                                <td class="col-price text-end">@priceComm.ToString("F2")</td>
                                <td class="col-price text-end" style="border-right:2px solid #dc3545">@priceNet.ToString("F2")</td>
                                <td class="text-center">
                                    @switch (lot.Status)
                                    {
                                        case LotStatus.Available: <span class="badge bg-success">Avail</span> break;
                                        case LotStatus.Reserved: <span class="badge bg-warning text-dark">Resv</span> break;
                                        case LotStatus.Sold: <span class="badge bg-secondary">Sold</span> break;
                                    }
                                </td>
                                <td class="text-center">
                                    @if (lot.HVIReportId.HasValue)
                                    {
                                        <button class="btn btn-link btn-sm p-0" @onclick="() => ShowHviModal(lot)">HVI ✓</button>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        @if (lot.Status == LotStatus.Available)
                                        { <button class="btn btn-outline-warning btn-sm py-0 px-1" @onclick="() => SetStatus(lot, LotStatus.Reserved)" title="Reserve">R</button> }
                                        @if (lot.Status == LotStatus.Reserved)
                                        { <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => SetStatus(lot, LotStatus.Sold)" title="Sold">S</button>
                                          <button class="btn btn-outline-success btn-sm py-0 px-1" @onclick="() => SetStatus(lot, LotStatus.Available)" title="Open">O</button> }
                                        @if (lot.Status == LotStatus.Sold)
                                        { <button class="btn btn-outline-success btn-sm py-0 px-1" @onclick="() => SetStatus(lot, LotStatus.Available)" title="Open">O</button> }
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => DeleteLot(lot)" title="Xóa">×</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── HVI Detail Modal ── *@
@if (showHviModal && hviLot != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">HVI Chi tiết — @hviLot.LotCode</h6>
                    <button type="button" class="btn-close" @onclick="CloseHviModal"></button>
                </div>
                <div class="modal-body">
                    @if (editingHvi != null)
                    {
                        <div class="row g-2">
                            <div class="col-6"><label class="form-label small">Micronaire</label><input type="number" step="0.01" class="form-control form-control-sm" @bind="editingHvi.Micronaire" /></div>
                            <div class="col-6"><label class="form-label small">Length</label><input type="number" step="0.01" class="form-control form-control-sm" @bind="editingHvi.Length" /></div>
                            <div class="col-6"><label class="form-label small">Strength GPT</label><input type="number" step="0.1" class="form-control form-control-sm" @bind="editingHvi.StrengthGPT" /></div>
                            <div class="col-6"><label class="form-label small">Uniformity</label><input type="number" step="0.1" class="form-control form-control-sm" @bind="editingHvi.Uniformity" /></div>
                            <div class="col-6"><label class="form-label small">Color Rd</label><input type="number" step="0.1" class="form-control form-control-sm" @bind="editingHvi.ColorRd" /></div>
                            <div class="col-6"><label class="form-label small">Color Grade</label><input class="form-control form-control-sm" @bind="editingHvi.ColorGrade" /></div>
                            <div class="col-6"><label class="form-label small">Leaf</label><input type="number" step="0.1" class="form-control form-control-sm" @bind="editingHvi.Leaf" /></div>
                            <div class="col-6"><label class="form-label small">Crop Year</label><input class="form-control form-control-sm" @bind="editingHvi.CropYear" /></div>
                            <div class="col-6"><label class="form-label small">Total Bales</label><input type="number" class="form-control form-control-sm" @bind="editingHvi.TotalBales" /></div>
                        </div>
                    }
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-primary btn-sm" @onclick="SaveHvi">Lưu HVI</button>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseHviModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const decimal LB_TO_KG = 2.20462m;

    // Price inputs
    private decimal iceValue = 84.19m;
    private decimal commissionPercent = 2.00m;

    // Data
    private List<Lot>? lots;
    private List<Shipper> shipperList = new();
    private List<string> originList = new();
    private HashSet<int> selectedLotIds = new();

    // Filters
    private int filterShipper = 0;
    private string filterOrigin = "";
    private int filterStatus = -1;
    private string filterLotCode = "";
    private DateTime? filterShipmentMonth;

    // HVI Modal
    private bool showHviModal = false;
    private Lot? hviLot;
    private HVIReport? editingHvi;

    // Offer Comparison
    private List<Offer> offerList = new();
    private int selectedOfferId = 0;
    private bool showOfferComparison = false;
    private List<OfferLot>? comparisonOfferLots;
    private string? comparisonPdfText;
    private int? highlightedOfferLotId;

    protected override async Task OnInitializedAsync()
    {
        shipperList = await Context.Shippers.Where(s => s.IsActive).OrderBy(s => s.Name).ToListAsync();
        originList = await Context.Lots.Select(l => l.Origin).Distinct().OrderBy(o => o).ToListAsync();
        offerList = await Context.Offers.OrderByDescending(o => o.CreatedAt).Take(30).ToListAsync();
        await LoadLots();
    }

    private decimal CalcPriceCkg(Lot lot)
    {
        var centsPerLb = lot.OutrightPrice > 0 ? lot.OutrightPrice : (iceValue + lot.BasisCents);
        return Math.Round(centsPerLb * LB_TO_KG, 2);
    }

    private async Task LoadLots()
    {
        var query = Context.Lots
            .Include(l => l.Shipper)
            .Include(l => l.HVIReport)
            .AsQueryable();

        if (filterShipper > 0)
            query = query.Where(l => l.ShipperId == filterShipper);
        if (!string.IsNullOrEmpty(filterOrigin))
            query = query.Where(l => l.Origin == filterOrigin);
        if (filterStatus >= 0)
            query = query.Where(l => (int)l.Status == filterStatus);
        if (!string.IsNullOrEmpty(filterLotCode))
            query = query.Where(l => l.LotCode.Contains(filterLotCode));
        if (filterShipmentMonth.HasValue)
        {
            var start = DateTime.SpecifyKind(new DateTime(filterShipmentMonth.Value.Year, filterShipmentMonth.Value.Month, 1), DateTimeKind.Utc);
            var end = start.AddMonths(1);
            query = query.Where(l => l.ShipmentDate >= start && l.ShipmentDate < end);
        }

        lots = await query
            .OrderBy(l => l.ShipmentDate)
            .ThenBy(l => l.Origin)
            .ThenBy(l => l.LotCode)
            .ToListAsync();
    }

    private async Task ApplyFilter() => await LoadLots();

    private async Task ClearFilter()
    {
        filterShipper = 0; filterOrigin = ""; filterStatus = -1; filterLotCode = ""; filterShipmentMonth = null;
        await LoadLots();
    }

    private async Task SetStatus(Lot lot, LotStatus newStatus)
    {
        lot.Status = newStatus;
        lot.UpdatedAt = DateTime.UtcNow;
        await Context.SaveChangesAsync();
        await LoadLots();
    }

    private async Task DeleteLot(Lot lot)
    {
        // Unlink OfferLots referencing this Lot
        var linkedOfferLots = await Context.OfferLots.Where(ol => ol.MasterLotId == lot.Id).ToListAsync();
        foreach (var ol in linkedOfferLots)
            ol.MasterLotId = null;

        // Unlink HVIReports referencing this Lot
        var linkedHvis = await Context.HVIReports.Where(h => h.MasterLotId == lot.Id).ToListAsync();
        foreach (var h in linkedHvis)
            h.MasterLotId = null;

        Context.Lots.Remove(lot);
        await Context.SaveChangesAsync();
        selectedLotIds.Remove(lot.Id);
        await LoadLots();
    }

    private async Task DeleteSelectedLots()
    {
        if (!selectedLotIds.Any() || lots == null) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Xác nhận xóa {selectedLotIds.Count} lot đã chọn?");
        if (!confirmed) return;

        var toDelete = lots.Where(l => selectedLotIds.Contains(l.Id)).ToList();
        foreach (var lot in toDelete)
        {
            var linkedOfferLots = await Context.OfferLots.Where(ol => ol.MasterLotId == lot.Id).ToListAsync();
            foreach (var ol in linkedOfferLots)
                ol.MasterLotId = null;

            var linkedHvis = await Context.HVIReports.Where(h => h.MasterLotId == lot.Id).ToListAsync();
            foreach (var h in linkedHvis)
                h.MasterLotId = null;

            Context.Lots.Remove(lot);
        }

        await Context.SaveChangesAsync();
        selectedLotIds.Clear();
        await LoadLots();
    }

    // ── Selection ──
    private void ToggleLot(int id, bool selected)
    {
        if (selected) selectedLotIds.Add(id); else selectedLotIds.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (lots == null) return;
        if ((bool)(e.Value ?? false))
            foreach (var l in lots) selectedLotIds.Add(l.Id);
        else
            selectedLotIds.Clear();
    }

    // ── HVI Modal ──
    private void ShowHviModal(Lot lot)
    {
        hviLot = lot;
        editingHvi = lot.HVIReport;
        showHviModal = true;
    }

    private void CloseHviModal() { showHviModal = false; hviLot = null; editingHvi = null; }

    private async Task SaveHvi()
    {
        if (editingHvi != null)
        {
            await Context.SaveChangesAsync();
            showHviModal = false;
        }
    }

    // ── Offer Comparison ──
    private async Task LoadOfferComparison()
    {
        if (selectedOfferId == 0)
        {
            comparisonOfferLots = null;
            comparisonPdfText = null;
            showOfferComparison = false;
            return;
        }

        var offer = await Context.Offers.FindAsync(selectedOfferId);
        comparisonPdfText = offer?.RawPdfText;
        comparisonOfferLots = await Context.OfferLots
            .Where(ol => ol.OfferId == selectedOfferId)
            .OrderBy(ol => ol.LotId)
            .ToListAsync();
        showOfferComparison = true;
    }

    private async Task HighlightOfferLot(OfferLot lot)
    {
        highlightedOfferLotId = lot.LotId;
        var searchTerms = new List<string>();
        if (!string.IsNullOrEmpty(lot.LotCode) && !lot.LotCode.Contains("-0") && lot.LotCode.Length > 3)
            searchTerms.Add(lot.LotCode.Split('-')[0]);
        if (lot.Quantity > 0) searchTerms.Add(((int)lot.Quantity).ToString());
        if (lot.OutrightPrice > 0) searchTerms.Add(lot.OutrightPrice.ToString("N2"));
        if (lot.BasisCents != 0) searchTerms.Add(((int)(lot.BasisCents * 100)).ToString());

        var searchJson = System.Text.Json.JsonSerializer.Serialize(searchTerms);
        await JS.InvokeVoidAsync("highlightPdfTextInPanel", "lotPdfTextPanel", searchJson);
        StateHasChanged();
    }

    // ── Export selected lots ──
    private async Task ExportSelectedLots()
    {
        if (lots == null || !selectedLotIds.Any()) return;

        var selected = lots.Where(l => selectedLotIds.Contains(l.Id)).ToList();

        var groups = selected
            .GroupBy(l => l.ShipmentDateText ?? (l.ShipmentDate.HasValue ? $"{l.ShipmentDate.Value:M/yyyy} SO" : "No Date"))
            .Select(g => new OutputGroupDto
            {
                ShipmentDate = g.First().ShipmentDate,
                GroupTitle = g.Key,
                Rows = g.Select((l, idx) =>
                {
                    var hvi = l.HVIReport;
                    var priceCkg = CalcPriceCkg(l);
                    return new OutputRowDto
                    {
                        STT = idx + 1,
                        Origin = l.Origin,
                        CropYear = l.CropYear ?? "",
                        Quantity = l.QuantityAvailable,
                        QuantityText = $"{l.QuantityAvailable:F0} mt",
                        Type = l.Type ?? "",
                        SpecialSpec = l.SpecialSpec,
                        Color = hvi?.ColorRd?.ToString("F0") ?? hvi?.ColorGrade,
                        Leaf = hvi?.Leaf,
                        Length = hvi?.Length,
                        Micronaire = hvi?.Micronaire,
                        StrengthMin = hvi?.StrengthGPT,
                        Basis = l.BasisCents,
                        ShipmentDate = l.ShipmentDate,
                        ShipmentDateText = l.ShipmentDateText,
                        PriceCentsPerKg = priceCkg,
                        PriceWithCommission = priceCkg - commissionPercent,
                        NetPrice = priceCkg - commissionPercent
                    };
                }).ToList()
            }).ToList();

        var bytes = await ExcelExport.GenerateExcelAsync(groups);
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{b64}';a.download='LotOutput_{DateTime.Now:yyyyMMdd_HHmm}.xlsx';a.click();");
    }
}
