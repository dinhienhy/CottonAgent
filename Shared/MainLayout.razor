@inherits LayoutComponentBase

<PageTitle>CBAS.Web</PageTitle>

<div class="page @(sidebarCollapsed ? "sidebar-collapsed" : "")">
    <div class="sidebar">
        <NavMenu Collapsed="sidebarCollapsed" />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="btn btn-sm btn-outline-secondary me-auto sidebar-toggle" @onclick="ToggleSidebar" title="Thu/mở menu">
                <span class="oi @(sidebarCollapsed ? "oi-menu" : "oi-arrow-left")"></span>
            </button>
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Welcome, <strong>@context.User.Identity?.Name</strong></span>
                    <a href="/Logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/Login" class="btn btn-sm btn-primary">Login</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool sidebarCollapsed = false;
    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;
}
