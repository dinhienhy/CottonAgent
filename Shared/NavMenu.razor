<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        @if (!Collapsed)
        {
            <a class="navbar-brand" href="">CBAS</a>
        }
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="Home">
                <span class="oi oi-home" aria-hidden="true"></span>@if (!Collapsed) { <text> Home</text> }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="offer-processor" title="Offer Processor">
                <span class="oi oi-document" aria-hidden="true"></span>@if (!Collapsed) { <text> Offer</text> }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="lots" title="Lots">
                <span class="oi oi-list-rich" aria-hidden="true"></span>@if (!Collapsed) { <text> Lots</text> }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="offers" title="Offers">
                <span class="oi oi-clipboard" aria-hidden="true"></span>@if (!Collapsed) { <text> Offers</text> }
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shippers" title="Shippers">
                <span class="oi oi-people" aria-hidden="true"></span>@if (!Collapsed) { <text> Shippers</text> }
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
