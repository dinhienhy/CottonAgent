@using Microsoft.AspNetCore.Components.Web
@namespace CBAS.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="CBAS.Web.styles.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script>
        window.downloadFile = function (filename, base64Content) {
            const link = document.createElement('a');
            link.download = filename;
            link.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,' + base64Content;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        window.highlightPdfLine = function (panelId, lineNumber) {
            const panel = document.getElementById(panelId || 'pdfTextPanel');
            if (!panel || lineNumber == null || lineNumber < 0) return;

            const original = panel.getAttribute('data-original') || panel.textContent;
            panel.setAttribute('data-original', original);

            const lines = original.split('\n');
            const highlighted = lines.map((line, idx) => {
                const escaped = line.replace(/</g,'&lt;').replace(/>/g,'&gt;');
                return idx === lineNumber
                    ? '<mark style="background:#ffe066;display:block;padding:2px 4px;">' + escaped + '</mark>'
                    : escaped;
            }).join('\n');

            panel.innerHTML = highlighted;

            const firstMark = panel.querySelector('mark');
            if (firstMark) {
                firstMark.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        };
    </script>
</body>
</html>
