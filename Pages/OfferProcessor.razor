@page "/offer-processor"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using CBAS.Web.Services
@using CBAS.Web.DTOs
@using CBAS.Web.Data
@using CBAS.Web.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject IOfferProcessingService OfferService
@inject IJSRuntime JSRuntime
@inject ApplicationDbContext DbContext

<PageTitle>Cotton Offer Processor</PageTitle>

<div class="container-fluid mt-4">
    <h2 class="mb-4">Hệ thống Xử lý Offer Bông</h2>

    @* ── Step indicator ── *@
    <div class="d-flex align-items-center mb-4">
        <span class="badge rounded-pill @(currentStep == 1 ? "bg-primary" : "bg-secondary") px-3 py-2 me-2">1. Upload</span>
        <i class="bi bi-arrow-right me-2"></i>
        <span class="badge rounded-pill @(currentStep == 2 ? "bg-primary" : "bg-secondary") px-3 py-2 me-2">2. Review HVI</span>
        <i class="bi bi-arrow-right me-2"></i>
        <span class="badge rounded-pill @(currentStep == 3 ? "bg-primary" : "bg-secondary") px-3 py-2">3. Kết quả</span>
    </div>

    @* ══════════════════════ STEP 1: UPLOAD ══════════════════════ *@
    @if (currentStep == 1)
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Bước 1: Upload Files</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@uploadModel" OnValidSubmit="@HandleUpload">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Shipper</label>
                            <select class="form-select" @bind="uploadModel.SupplierName">
                                <option value="">-- Chọn Shipper --</option>
                                @foreach (var s in shipperNames)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">ICE Value</label>
                            <InputNumber class="form-control" @bind-Value="uploadModel.ICEValue" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Commission (%)</label>
                            <InputNumber class="form-control" @bind-Value="uploadModel.CommissionPercent" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Offer PDF File</label>
                        <InputFile @key="offerFileKey" class="form-control" OnChange="@OnOfferFileSelected" accept=".pdf" />
                        @if (!string.IsNullOrEmpty(uploadModel.OfferFileName))
                        {
                            <div class="mt-2">
                                <span class="badge bg-success">✓ @uploadModel.OfferFileName</span>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">HVI Report PDF Files (Multiple)</label>
                        <InputFile @key="hviFileKey" class="form-control" OnChange="@OnHVIFilesSelected" accept=".pdf" multiple />
                        @if (hviFileNames.Any())
                        {
                            <div class="mt-2">
                                <small class="text-muted">Selected: @string.Join(", ", hviFileNames)</small>
                            </div>
                        }
                    </div>

                    <div class="mb-3 p-3 border rounded bg-light">
                        <label class="form-label fw-bold mb-1">Excel mẫu (AI Few-Shot Learning)</label>
                        <InputFile class="form-control" OnChange="@OnSampleExcelSelected" accept=".xlsx,.xls" />
                        @if (!string.IsNullOrEmpty(sampleExcelFileName))
                        {
                            <div class="mt-2">
                                <span class="badge bg-info">@sampleExcelFileName</span>
                            </div>
                        }
                        <small class="text-muted d-block mt-1">Upload file Excel kết quả mong muốn. AI sẽ học từ cặp PDF + Excel này (chỉ cần 1 lần/shipper).</small>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <text>Đang xử lý...</text>
                        }
                        else
                        {
                            <text>Phân tích Offer →</text>
                        }
                    </button>
                </EditForm>
            </div>
        </div>
    }

    @* ══════════════════════ AI LOG PANEL ══════════════════════ *@
    @if (aiLog != null)
    {
        <div class="card mb-3 @(aiLog.Status == "success" ? "border-success" : aiLog.Status == "error" ? "border-danger" : "border-secondary")">
            <div class="card-header py-2 d-flex justify-content-between align-items-center @(aiLog.Status == "success" ? "bg-success text-white" : aiLog.Status == "error" ? "bg-danger text-white" : "bg-secondary text-white")">
                <span>
                    <strong>AI Parser Log</strong>
                    @if (aiLog.Status == "success") { <text> — Thành công</text> }
                    else if (aiLog.Status == "error") { <text> — Lỗi</text> }
                    else if (!aiLog.Used) { <text> — Không dùng AI</text> }
                </span>
                <button class="btn btn-sm btn-outline-light" @onclick="() => showAiLogDetail = !showAiLogDetail">
                    @(showAiLogDetail ? "Thu gọn" : "Chi tiết")
                </button>
            </div>
            <div class="card-body py-2" style="font-size:0.8rem;">
                <div class="row g-2 mb-2">
                    <div class="col-auto"><span class="badge bg-dark">Model: @(aiLog.Model ?? "N/A")</span></div>
                    <div class="col-auto"><span class="badge bg-info text-dark">Tokens: @(aiLog.InputTokens?.ToString("N0") ?? "—") in / @(aiLog.OutputTokens?.ToString("N0") ?? "—") out</span></div>
                    @if (aiLog.CacheReadTokens > 0) { <div class="col-auto"><span class="badge bg-success">Cache HIT: @aiLog.CacheReadTokens.Value.ToString("N0") tokens</span></div> }
                    else if (aiLog.CacheCreationTokens > 0) { <div class="col-auto"><span class="badge bg-warning text-dark">Cache CREATED: @aiLog.CacheCreationTokens.Value.ToString("N0") tokens</span></div> }
                    <div class="col-auto"><span class="badge @(aiLog.StopReason == "max_tokens" ? "bg-warning text-dark" : "bg-secondary")">Stop: @(aiLog.StopReason ?? "—")</span></div>
                    <div class="col-auto"><span class="badge bg-primary">@(aiLog.ElapsedSeconds.ToString("F1"))s</span></div>
                    @if (aiLog.HasFewShot) { <div class="col-auto"><span class="badge bg-success">Few-Shot</span></div> }
                    @if (aiLog.FellBackToRegex) { <div class="col-auto"><span class="badge bg-warning text-dark">Fallback → Regex</span></div> }
                    @if (aiLog.LotsFound.HasValue) { <div class="col-auto"><span class="badge bg-success">@aiLog.LotsFound lots found</span></div> }
                </div>

                @if (!string.IsNullOrEmpty(aiLog.ErrorMessage))
                {
                    <div class="alert alert-danger py-1 px-2 mb-2 small"><strong>Error:</strong> @aiLog.ErrorMessage</div>
                }

                @if (showAiLogDetail)
                {
                    <div class="mb-2">
                        <strong class="small">Process Steps:</strong>
                        <ul class="list-unstyled mb-0 ms-2 small font-monospace" style="line-height:1.6">
                            @foreach (var step in aiLog.Steps)
                            {
                                <li>@step</li>
                            }
                        </ul>
                    </div>

                    @if (!string.IsNullOrEmpty(aiLog.RawResponse))
                    {
                        <details>
                            <summary class="small fw-bold cursor-pointer">Raw AI Response (click to expand)</summary>
                            <pre class="bg-dark text-light p-2 rounded mt-1 small" style="max-height:300px; overflow:auto; white-space:pre-wrap; font-size:0.7rem;">@aiLog.RawResponse</pre>
                        </details>
                    }
                }
            </div>
        </div>
    }

    @* ══════════════════════ SIDE-BY-SIDE COMPARISON ══════════════════════ *@
    @if ((currentStep == 2 || currentStep == 3) && parsedOfferLots?.Any() == true)
    {
        <div class="card mb-3">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
                <h6 class="mb-0">
                    <i class="bi bi-layout-split me-1"></i>
                    Đối chiếu PDF gốc ↔ Dữ liệu đã parse (@parsedOfferLots.Count lots)
                </h6>
                <button class="btn btn-sm btn-outline-light" @onclick="() => showComparison = !showComparison">
                    @(showComparison ? "Thu gọn ▲" : "Mở xem ▼")
                </button>
            </div>
            @if (showComparison)
            {
                <div class="card-body p-2" style="font-size:0.78rem;">
                    <div class="row g-2">
                        @* LEFT: Raw PDF Text *@
                        <div class="col-md-4">
                            <div class="border rounded p-2 bg-light" style="height:500px; overflow-y:auto;">
                                <h6 class="fw-bold text-muted mb-2">📄 PDF Text gốc</h6>
                                <pre id="pdfTextPanel" style="white-space:pre-wrap; font-size:0.72rem; font-family:monospace; line-height:1.5; margin:0;">@(rawPdfText ?? "Không có dữ liệu PDF text")</pre>
                            </div>
                        </div>
                        @* RIGHT: Parsed Lots Table *@
                        <div class="col-md-8">
                            <div class="border rounded" style="height:500px; overflow:auto;">
                                <table class="table table-bordered table-hover table-sm mb-0" style="font-size:0.72rem;">
                                    <thead class="table-dark sticky-top">
                                        <tr>
                                            <th style="width:30px">#</th>
                                            <th>LotCode</th>
                                            <th>Origin</th>
                                            <th>CropYear</th>
                                            <th>QTY</th>
                                            <th>Type</th>
                                            <th>Color</th>
                                            <th>Leaf</th>
                                            <th>Staple</th>
                                            <th>Mic</th>
                                            <th>Str</th>
                                            <th>Basis</th>
                                            <th>Fixed</th>
                                            <th>Settle</th>
                                            <th>Shipment</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ int rowNum = 0; }
                                        @foreach (var lot in parsedOfferLots)
                                        {
                                            rowNum++;
                                            var basisDisplay = lot.BasisCents != 0 ? (lot.BasisCents * 100).ToString("N0") : "";
                                            var fixedDisplay = lot.OutrightPrice != 0 ? lot.OutrightPrice.ToString("N2") : "";
                                            <tr class="@(highlightedLotId == lot.LotId ? "table-warning" : "")"
                                                @onclick="() => HighlightLot(lot)"
                                                style="cursor:pointer;" title="Click để tìm trong PDF text">
                                                <td class="text-muted">@rowNum</td>
                                                <td class="fw-bold text-nowrap">@lot.LotCode</td>
                                                <td>@lot.Origin</td>
                                                <td>@lot.CropYear</td>
                                                <td class="text-end">@(lot.Quantity > 0 ? lot.Quantity.ToString("N0") : "—")</td>
                                                <td>@lot.Type</td>
                                                <td>@lot.ColorSpec</td>
                                                <td>@lot.LeafSpec</td>
                                                <td>@lot.LengthSpec</td>
                                                <td>@lot.MicronaireSpec</td>
                                                <td>@lot.StrengthSpec</td>
                                                <td class="text-end">@basisDisplay</td>
                                                <td class="text-end">@fixedDisplay</td>
                                                <td>@lot.SettlementMonth</td>
                                                <td>@lot.ShipmentDateText</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="mt-1 text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        Click vào dòng lot để tìm và highlight text tương ứng trong PDF gốc.
                    </div>
                </div>
            }
        </div>
    }

    @* ══════════════════════ STEP 2: HVI REVIEW ══════════════════════ *@
    @if (currentStep == 2)
    {
        <div class="card">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Bước 2: Kiểm tra & Nhập dữ liệu HVI (@hviInputs.Count lot)</h5>
                <div>
                    @if (hviFileStreams.Any())
                    {
                        <button class="btn btn-info btn-sm me-2" @onclick="RunOcrForAll" disabled="@isRunningOcr">
                            @if (isRunningOcr)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                                <text>OCR đang chạy... (@ocrProgress/@hviInputs.Count)</text>
                            }
                            else
                            {
                                <text>🔍 Chạy OCR tất cả</text>
                            }
                        </button>
                    }
                    <button class="btn btn-outline-dark btn-sm" @onclick="SkipHVIReview">
                        Bỏ qua HVI →
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="alert alert-info mb-3">
                    <strong>Lưu ý:</strong> HVI PDF là file scan (ảnh). Hệ thống hỗ trợ OCR tự động (Tesseract).
                    Bạn <strong>bắt buộc kiểm tra & chỉnh sửa</strong> kết quả OCR trước khi lưu.
                    Nếu OCR không tốt, chọn "Nhập tay" để nhập từ đầu.
                </div>

                @for (int i = 0; i < hviInputs.Count; i++)
                {
                    var idx = i;
                    var hvi = hviInputs[idx];
                    var borderClass = hvi.OcrStatus == OcrStatus.Success ? "border-info" :
                                      hvi.HasData ? "border-success" : "border-warning";
                    var headerClass = hvi.OcrStatus == OcrStatus.Success ? "bg-info text-white" :
                                      hvi.HasData ? "bg-success text-white" : "bg-light";
                    <div class="card mb-3 @borderClass">
                        <div class="card-header d-flex justify-content-between align-items-center @headerClass">
                            <div>
                                <strong>Lot: @hvi.LotCode</strong>
                                @if (!string.IsNullOrEmpty(hvi.FileName))
                                {
                                    <small class="ms-2 opacity-75">(@hvi.FileName)</small>
                                }
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                @* OCR Status Badge *@
                                @switch (hvi.OcrStatus)
                                {
                                    case OcrStatus.Success:
                                        <span class="badge bg-light text-info" title="Confidence: @(hvi.ConfidenceScore * 100):F0%">
                                            🔍 OCR @((hvi.ConfidenceScore * 100).ToString("F0"))%
                                        </span>
                                        break;
                                    case OcrStatus.Failed:
                                        <span class="badge bg-danger" title="@hvi.OcrErrorMessage">✗ OCR lỗi</span>
                                        break;
                                    case OcrStatus.Processing:
                                        <span class="badge bg-secondary">
                                            <span class="spinner-border spinner-border-sm" style="width:0.7rem;height:0.7rem"></span> OCR...
                                        </span>
                                        break;
                                }

                                @* Data Status Badge *@
                                @if (hvi.HasData)
                                {
                                    <span class="badge bg-light text-success">✓ Có dữ liệu</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chưa nhập</span>
                                }

                                <button class="btn btn-sm @(expandedLots.Contains(hvi.LotCode) ? "btn-outline-secondary" : "btn-outline-primary")"
                                        @onclick="() => ToggleLotExpand(hvi.LotCode)">
                                    @(expandedLots.Contains(hvi.LotCode) ? "Thu gọn ▲" : "Mở rộng ▼")
                                </button>
                            </div>
                        </div>

                        @if (expandedLots.Contains(hvi.LotCode))
                        {
                            <div class="card-body">
                                @* OCR action buttons *@
                                @if (hviFileStreams.ContainsKey(hvi.LotCode))
                                {
                                    <div class="mb-3 d-flex gap-2">
                                        <button class="btn btn-outline-info btn-sm" @onclick="() => RunOcrForSingleLot(idx)"
                                                disabled="@(hvi.OcrStatus == OcrStatus.Processing)">
                                            🔍 Chạy OCR
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => ClearLotData(idx)">
                                            🗑 Xóa & Nhập tay
                                        </button>
                                        @if (!string.IsNullOrEmpty(hvi.RawOcrText))
                                        {
                                            <button class="btn btn-outline-dark btn-sm" @onclick="() => ToggleRawText(hvi.LotCode)">
                                                @(showRawText.Contains(hvi.LotCode) ? "Ẩn raw text" : "Xem raw OCR text")
                                            </button>
                                        }
                                    </div>
                                }

                                @* Raw OCR text display *@
                                @if (showRawText.Contains(hvi.LotCode) && !string.IsNullOrEmpty(hvi.RawOcrText))
                                {
                                    <div class="mb-3 p-2 bg-dark text-light rounded" style="max-height:200px;overflow-y:auto;font-size:0.8rem;font-family:monospace;white-space:pre-wrap;">@hvi.RawOcrText</div>
                                }

                                @* OCR error message *@
                                @if (hvi.OcrStatus == OcrStatus.Failed && !string.IsNullOrEmpty(hvi.OcrErrorMessage))
                                {
                                    <div class="alert alert-warning alert-sm py-1 px-2 mb-3">
                                        <small>⚠ @hvi.OcrErrorMessage — Vui lòng nhập tay.</small>
                                    </div>
                                }

                                @* HVI data input fields *@
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Micronaire (Mic)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.Micronaire" @onchange="e => hvi.Micronaire = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 4.47</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Chiều dài (Len)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.Length" @onchange="e => hvi.Length = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 112.87</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Cường lực (GPT)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.StrengthGPT" @onchange="e => hvi.StrengthGPT = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 30.84</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Uniformity (Unif)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.Uniformity" @onchange="e => hvi.Uniformity = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 81.33</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Màu sắc (Rd)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.ColorRd" @onchange="e => hvi.ColorRd = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 74.67</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Color Grade</label>
                                        <input type="text" class="form-control"
                                               value="@hvi.ColorGrade" @onchange="e => hvi.ColorGrade = e.Value?.ToString()" />
                                        <small class="text-muted">VD: 41-1</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-bold">Tạp lá (Leaf)</label>
                                        <input type="number" step="0.01" class="form-control"
                                               value="@hvi.Leaf" @onchange="e => hvi.Leaf = ParseDecimal(e.Value)" />
                                        <small class="text-muted">VD: 3.32</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Crop Year</label>
                                        <input type="text" class="form-control"
                                               value="@hvi.CropYear" @onchange="e => hvi.CropYear = e.Value?.ToString()" />
                                        <small class="text-muted">VD: 2025</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Total Bales</label>
                                        <input type="number" class="form-control"
                                               value="@hvi.TotalBales" @onchange="e => hvi.TotalBales = ParseInt(e.Value)" />
                                        <small class="text-muted">VD: 1798</small>
                                    </div>
                                    <div class="col-md-9">
                                        <label class="form-label">Ghi chú</label>
                                        <input type="text" class="form-control"
                                               value="@hvi.Notes" @onchange="e => hvi.Notes = e.Value?.ToString()" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (hviInputs.Count == 0)
                {
                    <div class="alert alert-secondary">
                        Không có lot nào cần nhập HVI (tất cả là generic offer lines).
                    </div>
                }

                <div class="d-flex justify-content-between mt-3">
                    <button class="btn btn-secondary" @onclick="GoBackToStep1">
                        ← Quay lại
                    </button>
                    <div>
                        <button class="btn btn-outline-primary me-2" @onclick="ExpandAllLots">
                            Mở tất cả
                        </button>
                        <button class="btn btn-success btn-lg" @onclick="SaveHVIAndCalculate" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <text>Đang lưu...</text>
                            }
                            else
                            {
                                <text>Lưu HVI & Tính toán →</text>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ══════════════════════ STEP 3: RESULTS ══════════════════════ *@
    @if (currentStep == 3)
    {
        <div class="card">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Bước 3: Kết quả xử lý</h5>
                <div>
                    <button class="btn btn-light btn-sm me-2" @onclick="GoBackToHVIReview">
                        ← Sửa HVI
                    </button>
                    <button class="btn btn-light btn-sm me-2" @onclick="ExportToExcel">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="ResetForm">
                        <i class="bi bi-arrow-clockwise"></i> Offer mới
                    </button>
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(syncLog))
                {
                    <div class="alert alert-info py-2 small mb-2">
                        <i class="bi bi-database-check me-1"></i><strong>Sync DB:</strong> @syncLog
                    </div>
                }
                @if (outputGroups != null && outputGroups.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover table-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th>STT</th>
                                    <th>Origin</th>
                                    <th>Crop Year</th>
                                    <th>Số lượng</th>
                                    <th>Loại bông</th>
                                    <th>Chỉ tiêu đặc biệt</th>
                                    <th>Màu sắc</th>
                                    <th>Tạp lá</th>
                                    <th>Chiều dài</th>
                                    <th>Micronaire</th>
                                    <th>Cường lực Min</th>
                                    <th>Basis</th>
                                    <th>Shipment Date</th>
                                    <th>Giá (c/kg)</th>
                                    <th>Giá có Commission</th>
                                    <th>Giá net</th>
                                    <th>Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var group in outputGroups)
                                {
                                    <tr class="table-info">
                                        <td colspan="17" class="fw-bold">@group.GroupTitle</td>
                                    </tr>
                                    @foreach (var row in group.Rows)
                                    {
                                        <tr>
                                            <td>@row.STT</td>
                                            <td>@row.Origin</td>
                                            <td>@row.CropYear</td>
                                            <td>@(row.QuantityText ?? row.Quantity.ToString("N0") + " mt")</td>
                                            <td>@row.Type</td>
                                            <td>@row.SpecialSpec</td>
                                            <td>@row.Color</td>
                                            <td>@(row.Leaf?.ToString("N2"))</td>
                                            <td>@(row.Length?.ToString("N0"))</td>
                                            <td>@(row.MicronaireText ?? row.Micronaire?.ToString("N2"))</td>
                                            <td>@(row.StrengthText ?? row.StrengthMin?.ToString("N2"))</td>
                                            <td>@row.Basis.ToString("N0")</td>
                                            <td>@(row.ShipmentDateText ?? row.ShipmentDate?.ToString("M/yyyy") + " SO")</td>
                                            <td>@row.PriceCentsPerKg.ToString("N2") c/kg</td>
                                            <td>@row.PriceWithCommission.ToString("N2")</td>
                                            <td>@row.NetPrice.ToString("N2")</td>
                                            <td>@row.Notes</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">Không có dữ liệu</div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">
            <strong>Lỗi:</strong> @errorMessage
        </div>
    }
</div>

@code {
    // ── State ──
    private int currentStep = 1;
    private List<string> shipperNames = new();
    private OfferUploadDto uploadModel = new()
    {
        SupplierName = "",
        ICEValue = 84.19m,
        CommissionPercent = 2.00m,
        OfferDate = DateTime.UtcNow.Date
    };
    private List<string> hviFileNames = new();
    private string? sampleExcelFileName;
    private MemoryStream? sampleExcelStream;
    private ClaudeParseLog? aiLog;
    private bool showAiLogDetail = false;
    private string? syncLog;
    private string? rawPdfText;
    private List<OfferLot>? parsedOfferLots;
    private bool showComparison = false;
    private int? highlightedLotId;

    protected override async Task OnInitializedAsync()
    {
        shipperNames = await DbContext.Shippers
            .Where(s => s.IsActive)
            .OrderBy(s => s.Name)
            .Select(s => s.Name)
            .ToListAsync();
    }
    private List<HVIInputDto> hviInputs = new();
    private HashSet<string> expandedLots = new();
    private HashSet<string> showRawText = new();
    private Dictionary<string, MemoryStream> hviFileStreams = new();
    private List<OutputGroupDto>? outputGroups;
    private bool isProcessing = false;
    private bool isSaving = false;
    private bool isRunningOcr = false;
    private int ocrProgress = 0;
    private string? errorMessage;
    private int currentOfferId;

    private string offerFileKey = "offer-1";
    private string hviFileKey = "hvi-1";

    // ── Step 1: File selection handlers ──
    private async Task OnOfferFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            errorMessage = null;
            var file = e.File;
            if (file != null)
            {
                uploadModel.OfferFileName = file.Name;
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                memoryStream.Position = 0;
                uploadModel.OfferPdfStream = memoryStream;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi load file offer: {ex.Message}";
        }
    }

    private async Task OnHVIFilesSelected(InputFileChangeEventArgs e)
    {
        try
        {
            errorMessage = null;
            uploadModel.HVIFiles.Clear();
            hviFileNames.Clear();
            hviFileStreams.Clear();

            // Collect file references first (no await between GetMultipleFiles and OpenReadStream)
            var files = e.GetMultipleFiles(20);
            var fileList = files.ToList(); // materialize immediately

            // Record names first (no async needed)
            foreach (var file in fileList)
                hviFileNames.Add(file.Name);

            // Now read each file - use ReadAsync on each with error handling
            foreach (var file in fileList)
            {
                try
                {
                    using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    memoryStream.Position = 0;

                    uploadModel.HVIFiles.Add(new HVIFileDto { FileName = file.Name, FileStream = memoryStream });
                    var lotCode = System.IO.Path.GetFileNameWithoutExtension(file.Name);
                    hviFileStreams[lotCode] = memoryStream;
                }
                catch (Exception fileEx)
                {
                    Console.Error.WriteLine($"Failed to read HVI file {file.Name}: {fileEx.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi load file HVI: {ex.Message}";
        }
    }

    private async Task OnSampleExcelSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file != null)
            {
                sampleExcelFileName = file.Name;
                var ms = new MemoryStream();
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                await stream.CopyToAsync(ms);
                ms.Position = 0;
                sampleExcelStream = ms;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi load file Excel mẫu: {ex.Message}";
        }
    }

    // ── Step 1 → Step 2 ──
    private async Task HandleUpload()
    {
        try
        {
            if (uploadModel.OfferPdfStream == null)
            {
                errorMessage = "Vui lòng chọn file Offer PDF";
                return;
            }
            if (string.IsNullOrWhiteSpace(uploadModel.SupplierName))
            {
                errorMessage = "Vui lòng nhập tên Supplier";
                return;
            }

            isProcessing = true;
            errorMessage = null;
            aiLog = null;
            showAiLogDetail = false;
            StateHasChanged();

            currentOfferId = await OfferService.ProcessOfferAsync(uploadModel);

            // Capture AI processing log
            aiLog = OfferService.LastAILog;
            StateHasChanged();

            // Save AI sample if Excel mẫu was uploaded
            if (sampleExcelStream != null && uploadModel.OfferPdfStream != null)
            {
                await SaveShipperSample();
            }

            hviInputs = await OfferService.GetHVIForReviewAsync(currentOfferId);

            // Load data for side-by-side comparison
            rawPdfText = OfferService.LastRawPdfText;
            parsedOfferLots = await OfferService.GetOfferLotsAsync(currentOfferId);

            // Auto-expand all lots
            expandedLots = new HashSet<string>(hviInputs.Select(h => h.LotCode));

            currentStep = 2;

            // Auto-run OCR if HVI files were uploaded
            if (hviFileStreams.Any() && hviInputs.Any())
            {
                _ = RunOcrForAll();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi xử lý offer: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    // ── Step 2: OCR ──
    private async Task RunOcrForAll()
    {
        isRunningOcr = true;
        ocrProgress = 0;
        StateHasChanged();

        for (int i = 0; i < hviInputs.Count; i++)
        {
            var hvi = hviInputs[i];
            if (hviFileStreams.TryGetValue(hvi.LotCode, out var stream))
            {
                if (!hvi.HasData) // Only OCR if no existing data
                {
                    await RunOcrForSingleLot(i);
                }
            }
            ocrProgress = i + 1;
            StateHasChanged();
        }

        isRunningOcr = false;
        StateHasChanged();
    }

    private async Task RunOcrForSingleLot(int idx)
    {
        var hvi = hviInputs[idx];
        if (!hviFileStreams.TryGetValue(hvi.LotCode, out var stream)) return;

        hvi.OcrStatus = OcrStatus.Processing;
        StateHasChanged();

        try
        {
            stream.Position = 0;
            var result = await OfferService.RunOcrForLotAsync(hvi.LotCode, stream, hvi.FileName);

            // Merge OCR result into current input
            hvi.Micronaire = result.Micronaire;
            hvi.Length = result.Length;
            hvi.StrengthGPT = result.StrengthGPT;
            hvi.Uniformity = result.Uniformity;
            hvi.ColorRd = result.ColorRd;
            hvi.ColorGrade = result.ColorGrade;
            hvi.Leaf = result.Leaf;
            hvi.CropYear = result.CropYear;
            hvi.TotalBales = result.TotalBales;
            hvi.ConfidenceScore = result.ConfidenceScore;
            hvi.RawOcrText = result.RawOcrText;
            hvi.OcrStatus = result.OcrStatus;
            hvi.OcrErrorMessage = result.OcrErrorMessage;
        }
        catch (Exception ex)
        {
            hvi.OcrStatus = OcrStatus.Failed;
            hvi.OcrErrorMessage = ex.Message;
        }

        StateHasChanged();
    }

    private void ClearLotData(int idx)
    {
        var hvi = hviInputs[idx];
        hvi.Micronaire = null;
        hvi.Length = null;
        hvi.StrengthGPT = null;
        hvi.Uniformity = null;
        hvi.ColorRd = null;
        hvi.ColorGrade = null;
        hvi.Leaf = null;
        hvi.CropYear = null;
        hvi.TotalBales = null;
        hvi.OcrStatus = OcrStatus.Skipped;
        hvi.RawOcrText = null;
        hvi.ConfidenceScore = 0;
        StateHasChanged();
    }

    private void ToggleRawText(string lotCode)
    {
        if (!showRawText.Remove(lotCode))
            showRawText.Add(lotCode);
        StateHasChanged();
    }

    // ── Side-by-side: Highlight lot in PDF text ──
    private async Task HighlightLot(OfferLot lot)
    {
        highlightedLotId = lot.LotId;
        // First element = primary (LotCode), rest = secondary (need >=2 to match)
        var searchTerms = new List<string>();
        var code = lot.LotCode?.Trim() ?? "";
        if (code.Length > 2) searchTerms.Add(code);
        else searchTerms.Add(""); // placeholder so index 0 = primary
        if (lot.Quantity > 0) searchTerms.Add(((int)lot.Quantity).ToString());
        if (lot.BasisCents != 0) searchTerms.Add(((int)(lot.BasisCents * 100)).ToString());
        if (lot.OutrightPrice > 0) searchTerms.Add(lot.OutrightPrice.ToString("N2"));

        var searchJson = System.Text.Json.JsonSerializer.Serialize(searchTerms);
        await JSRuntime.InvokeVoidAsync("highlightPdfText", searchJson);
        StateHasChanged();
    }

    // ── Step 2: HVI Review helpers ──
    private void ToggleLotExpand(string lotCode)
    {
        if (!expandedLots.Remove(lotCode))
            expandedLots.Add(lotCode);
    }

    private void ExpandAllLots()
    {
        expandedLots = new HashSet<string>(hviInputs.Select(h => h.LotCode));
        StateHasChanged();
    }

    // ── Step 2 → Step 3 ──
    private async Task SaveHVIAndCalculate()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            StateHasChanged();

            await OfferService.SaveHVIDataAsync(hviInputs);
            await OfferService.RecalculateOutputsAsync(currentOfferId);
            syncLog = OfferService.LastSyncLog;
            outputGroups = await OfferService.GetProcessedOutputAsync(currentOfferId);

            currentStep = 3;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi lưu HVI: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SkipHVIReview()
    {
        await SaveHVIAndCalculate();
    }

    // ── Navigation ──
    private void GoBackToStep1()
    {
        currentStep = 1;
        StateHasChanged();
    }

    private async Task GoBackToHVIReview()
    {
        hviInputs = await OfferService.GetHVIForReviewAsync(currentOfferId);
        expandedLots = new HashSet<string>(hviInputs.Select(h => h.LotCode));
        currentStep = 2;
        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        try
        {
            var excelBytes = await OfferService.ExportToExcelAsync(currentOfferId);
            var fileName = $"CottonOffer_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(excelBytes));
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi export Excel: {ex.Message}";
        }
    }

    private void ResetForm()
    {
        currentStep = 1;
        uploadModel = new()
        {
            SupplierName = "Toyoshima",
            ICEValue = 84.19m,
            CommissionPercent = 2.00m,
            OfferDate = DateTime.UtcNow.Date
        };
        hviFileNames.Clear();
        hviInputs.Clear();
        hviFileStreams.Clear();
        expandedLots.Clear();
        showRawText.Clear();
        outputGroups = null;
        errorMessage = null;
        rawPdfText = null;
        parsedOfferLots = null;
        showComparison = false;
        highlightedLotId = null;
    }

    // ── Save Shipper Sample for AI Few-Shot ──
    private async Task SaveShipperSample()
    {
        try
        {
            var shipper = await DbContext.Shippers
                .FirstOrDefaultAsync(s => s.Name == uploadModel.SupplierName);
            if (shipper == null) return;

            var existing = await DbContext.ShipperSamples
                .FirstOrDefaultAsync(ss => ss.ShipperId == shipper.ShipperId);

            uploadModel.OfferPdfStream!.Position = 0;
            using var pdfMs = new MemoryStream();
            await uploadModel.OfferPdfStream.CopyToAsync(pdfMs);
            var pdfBytes = pdfMs.ToArray();

            sampleExcelStream!.Position = 0;
            var excelBytes = sampleExcelStream.ToArray();

            // Extract text from PDF for prompt
            uploadModel.OfferPdfStream.Position = 0;
            string? extractedText = null;
            try
            {
                using var doc = UglyToad.PdfPig.PdfDocument.Open(uploadModel.OfferPdfStream);
                var rows = new List<string>();
                foreach (var page in doc.GetPages())
                {
                    var words = page.GetWords().ToList();
                    if (words.Count == 0) continue;
                    var pageRows = words
                        .GroupBy(w => Math.Round(w.BoundingBox.Bottom, 0))
                        .OrderByDescending(g => g.Key)
                        .Select(g => string.Join(" ", g.OrderBy(w => w.BoundingBox.Left).Select(w => w.Text)));
                    rows.AddRange(pageRows);
                }
                extractedText = string.Join("\n", rows);
            }
            catch { }

            // Extract Excel content as JSON for prompt
            string? excelJson = null;
            try
            {
                sampleExcelStream.Position = 0;
                using var workbook = new ClosedXML.Excel.XLWorkbook(sampleExcelStream);
                var ws = workbook.Worksheets.First();
                var rowsData = new List<Dictionary<string, string>>();
                var headers = new List<string>();
                var lastRow = ws.LastRowUsed()?.RowNumber() ?? 0;
                var lastCol = ws.LastColumnUsed()?.ColumnNumber() ?? 0;

                for (int c = 1; c <= lastCol; c++)
                    headers.Add(ws.Cell(1, c).GetString());

                for (int r = 2; r <= Math.Min(lastRow, 50); r++)
                {
                    var row = new Dictionary<string, string>();
                    for (int c = 1; c <= lastCol; c++)
                        row[headers[c - 1]] = ws.Cell(r, c).GetString();
                    rowsData.Add(row);
                }
                excelJson = System.Text.Json.JsonSerializer.Serialize(rowsData);
            }
            catch { }

            if (existing != null)
            {
                existing.SampleOfferPdf = pdfBytes;
                existing.SampleOfferFileName = uploadModel.OfferFileName;
                existing.SampleExcelResult = excelBytes;
                existing.SampleExcelFileName = sampleExcelFileName;
                existing.ExtractedPdfText = extractedText;
                existing.ExtractedExcelJson = excelJson;
                existing.UpdatedAt = DateTime.UtcNow;
            }
            else
            {
                DbContext.ShipperSamples.Add(new Models.ShipperSample
                {
                    ShipperId = shipper.ShipperId,
                    SampleOfferPdf = pdfBytes,
                    SampleOfferFileName = uploadModel.OfferFileName,
                    SampleExcelResult = excelBytes,
                    SampleExcelFileName = sampleExcelFileName,
                    ExtractedPdfText = extractedText,
                    ExtractedExcelJson = excelJson,
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow,
                });
            }

            await DbContext.SaveChangesAsync();
            Console.WriteLine($"[AI Sample] Saved sample for shipper: {uploadModel.SupplierName}");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[AI Sample] Error saving sample: {ex.Message}");
        }
    }

    // ── Helpers ──
    private decimal? ParseDecimal(object? value)
    {
        if (value == null || string.IsNullOrWhiteSpace(value.ToString())) return null;
        return decimal.TryParse(value.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;
    }

    private int? ParseInt(object? value)
    {
        if (value == null || string.IsNullOrWhiteSpace(value.ToString())) return null;
        return int.TryParse(value.ToString(), out var i) ? i : null;
    }
}
