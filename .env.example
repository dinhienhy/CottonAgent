# Environment Variables Template
# Copy this file to .env and update values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cbas_db
DB_USER=postgres
DB_PASSWORD=postgres

# Connection String (alternative to individual DB vars)
# ConnectionStrings__DefaultConnection=Host=localhost;Database=cbas_db;Username=postgres;Password=postgres

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# Heroku/Production (uncomment when deploying)
# PORT=5000
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Security
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123  # CHANGE THIS IN PRODUCTION!

# File Upload Limits
MAX_FILE_SIZE_MB=10
MAX_HVI_FILES=20

# Processing Settings
DEFAULT_ICE_VALUE=84.19
DEFAULT_COMMISSION=2.00

# Email Settings (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@cbas.local

# Logging
# LOG_LEVEL=Information
# LOG_TO_FILE=true

# Claude AI Parser (Anthropic API)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Feature Flags (for future use)
# ENABLE_BID_MATCHING=false
# ENABLE_EMAIL_NOTIFICATIONS=false
# ENABLE_API=false
