@inherits LayoutComponentBase

<PageTitle>CBAS.Web</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Welcome, <strong>@context.User.Identity?.Name</strong></span>
                    <a href="/Logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/Login" class="btn btn-sm btn-primary">Login</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
